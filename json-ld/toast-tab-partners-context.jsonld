    },
    "isoCreatedDate": {
      "@id": "toast:isoCreatedDate",
      "@type": "xsd:string"
    },
    "PartnerAccessExternalWebhookRep": "toast:PartnerAccessExternalWebhookRep",
    "createdByFirstName": {
      "@id": "toast:createdByFirstName",
      "@type": "xsd:string"
    },
